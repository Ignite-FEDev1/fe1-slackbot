{
  "name": "fe1_slack_bot",
  "version": "0.1.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "deploy": "npm run build && NODE_TLS_REJECT_UNAUTHORIZED=0 sls deploy",
    "offline": "npm run build && serverless offline",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=app.js --format=cjs",
    "build:local": "esbuild src/local.ts --bundle --platform=node --outfile=local.js --format=cjs",
    "dev": "npm run build:local && node local.js",
    "dev:watch": "npm run build:local -- --watch & node --watch local.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "serverless-offline": "^13.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1028.0",
    "@slack/bolt": "^3.19.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/axios": "^0.14.0",
    "axios": "^1.7.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.23.0",
    "express": "^4.19.2",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5"
  }
}
